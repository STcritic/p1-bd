APP_NAME="Business Diversity"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://bdiversity.co.mz
APP_TIMEZONE=Africa/Maputo
FORCE_HTTPS=true
TRUSTED_PROXIES=*

APP_LOCALE=pt
APP_FALLBACK_LOCALE=pt
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cpaneluser_bd_site
DB_USERNAME=cpaneluser_bd_user
DB_PASSWORD="coloque-a-password-do-mysql"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.bdiversity.co.mz
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=database

BD_INTRANET_URL=https://bdiversity.co.mz/intranet
ANNOUNCEMENT_MASTER_EMAIL=info@bdiversity.co.mz
ANNOUNCEMENT_MASTER_PASSWORD="coloque-a-password-master"
ANNOUNCEMENT_PASSWORD_EXPIRES_MONTHS=6

MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=mail.bdiversity.co.mz
MAIL_PORT=465
MAIL_EHLO_DOMAIN=bdiversity.co.mz
MAIL_TIMEOUT=10
MAIL_USERNAME=no_reply@bdiversity.co.mz
MAIL_PASSWORD="coloque-a-password-do-email"
MAIL_FROM_ADDRESS=no_reply@bdiversity.co.mz
MAIL_FROM_NAME="Business Diversity"
MAIL_REPLY_TO_ADDRESS=info@bdiversity.co.mz
MAIL_REPLY_TO_NAME="Business Diversity"
MAIL_CONTACT_TO=info@bdiversity.co.mz
BD_NOTIFICATIONS_ENABLED=true
BD_NOTIFICATION_EMAIL=info@bdiversity.co.mz
BD_NOTIFICATION_NAME="Business Diversity"

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

OCR_SPACE_API_KEY=
OCR_SPACE_ENGINE=2
